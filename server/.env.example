# ─── Database ────────────────────────────────────────────────────────────────
# Absolute path to the SQLite database written by the scraper.
DB_PATH=/path/to/educative_scraper.db

# ─── Next.js cache revalidation ──────────────────────────────────────────────
# Full URL of the Next.js revalidation endpoint.
NEXTJS_WEBHOOK_URL=http://localhost:3000/webhook

# Shared secret — must match REVALIDATE_SECRET in client/.env.local
# Leave blank to disable secret checking on the Next.js side (dev only).
REVALIDATE_SECRET=change-me

# ─── /backend/notify endpoint auth ───────────────────────────────────────────
# Secret that external callers must send when POSTing to /backend/notify.
# Leave blank to allow unauthenticated calls (dev only).
NOTIFY_SECRET=change-me

# ─── Background DB watcher ───────────────────────────────────────────────────
# Set WATCH_DB_CHANGES=1 to enable the background thread that polls the SQLite
# database and automatically revalidates Next.js caches when rows change.
WATCH_DB_CHANGES=0

# How often (in seconds) to poll the database for changes.
WATCH_INTERVAL=10

# How many seconds of DB inactivity to wait before flushing pending tags to
# the webhook. Prevents a burst of calls during a long scrape run.
DEBOUNCE_DELAY=15


# ─── Auth ─────────────────────────────────────────────────────────────────────
# Same secret as NEXT_PUBLIC_... NEVER share — must match Next.js JWT_SECRET
JWT_SECRET=changeme-dev-secret
JWT_EXPIRES_DAYS=7
# Separate SQLite DB for users (auto-created on first run)
AUTH_DB_PATH=
# Comma-separated allowed invite codes (leave empty to accept any non-empty code)
INVITE_CODES=abcdef
# Issuer label shown in authenticator apps
TOTP_ISSUER=EduViewer

# -- Client-Server internal API token (protects /courses, /course-details, /topic-details)
CLIENT_SERVER_SECRET=cs-internal-dev-secret-change-in-prod